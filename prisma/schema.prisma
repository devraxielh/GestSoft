generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Role {
  id          Int          @id @default(autoincrement())
  name        String       @unique
  createdAt   DateTime     @default(now())
  users       User[]
  permissions Permission[] @relation("PermissionToRole")
}

model Permission {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  roles       Role[]   @relation("PermissionToRole")
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  image     String?
  roles     Role[]
}

model Faculty {
  id       Int       @id @default(autoincrement())
  name     String    @unique
  sedeId   Int?
  address  String?
  deanId   Int?
  email    String?
  phone    String?
  presentation String?  @db.LongText
  programs Program[]

  sede     Sede?     @relation(fields: [sedeId], references: [id], onDelete: Cascade)
  dean     Person?   @relation("FacultyDean", fields: [deanId], references: [id])
  @@index([sedeId])
  @@index([deanId])
}

model Program {
  id           Int      @id @default(autoincrement())
  name         String   @unique
  type         String?
  status       String?
  facultyId    Int
  address      String?
  directorId   Int?
  email        String?
  phone        String?
  presentation String?  @db.LongText
  persons      Person[]
  theses       Thesis[]
  faculty      Faculty  @relation(fields: [facultyId], references: [id])
  director     Person?  @relation("ProgramDirector", fields: [directorId], references: [id])
  docentes     Docente[]
  documentos   Documento[]

  @@index([facultyId], map: "Program_facultyId_fkey")
}

model Docente {
  id              Int      @id @default(autoincrement())
  personId        Int
  programId       Int
  contractType    String?
  dedication      String?
  teacherType     String?
  person          Person   @relation(fields: [personId], references: [id])
  program         Program  @relation(fields: [programId], references: [id])

  @@index([personId])
  @@index([programId])
}

model Person {
  id             Int                     @id @default(autoincrement())
  idType         String
  identification String                  @unique
  phone          String?
  email          String?
  createdAt      DateTime                @default(now())
  programId      Int?
  fullName       String
  assignments    CertificateAssignment[]
  program        Program?                @relation(fields: [programId], references: [id])

  studentTheses  ThesisStudent[]
  advisorTheses  ThesisAdvisor[]
  juryTheses     ThesisJury[]

  sedesAsRector  Sede[]                  @relation("SedeRector")
  directivos     Directivo[]
  facultiesAsDean Faculty[]              @relation("FacultyDean")
  programsAsDirector Program[]           @relation("ProgramDirector")
  docenteInfo    Docente[]

  @@index([programId], map: "Person_programId_fkey")
}

model Event {
  id           Int           @id @default(autoincrement())
  name         String
  startDate    DateTime
  endDate      DateTime
  description  String?       @db.Text
  eventType    String
  createdAt    DateTime      @default(now())
  status       String        @default("Realizado")
  certificates Certificate[]
}

model Certificate {
  id                Int                     @id @default(autoincrement())
  participationType String
  templateHtml      String                  @db.LongText
  eventId           Int
  issueDate         DateTime
  createdAt         DateTime                @default(now())
  event             Event                   @relation(fields: [eventId], references: [id])
  assignments       CertificateAssignment[]

  @@index([eventId], map: "Certificate_eventId_fkey")
}

model CertificateAssignment {
  id                   Int         @id @default(autoincrement())
  certificateId        Int
  personId             Int
  createdAt            DateTime    @default(now())
  participationDetails String?     @db.Text
  certificate          Certificate @relation(fields: [certificateId], references: [id])
  person               Person      @relation(fields: [personId], references: [id])

  @@index([personId], map: "CertificateAssignment_personId_fkey")
  @@index([certificateId], map: "CertificateAssignment_certificateId_fkey")
}

model Thesis {
  id               Int       @id @default(autoincrement())
  title            String    @db.Text
  level            String    // pregrado, especializacion, maestria, doctorado
  defenseDate      DateTime?
  grade            Float?
  status           String    @default("En desarrollo") // en desarrollo, terminada
  programId        Int
  createdAt        DateTime  @default(now())
  
  program      Program   @relation(fields: [programId], references: [id])
  students     ThesisStudent[]
  advisors     ThesisAdvisor[]
  juries       ThesisJury[]

  @@index([programId])
}

model ThesisStudent {
  id        Int      @id @default(autoincrement())
  thesisId  Int
  personId  Int
  joinedAt  DateTime @default(now())

  thesis    Thesis   @relation(fields: [thesisId], references: [id], onDelete: Cascade)
  person    Person   @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@unique([thesisId, personId])
  @@index([personId])
  @@index([thesisId])
}

model ThesisAdvisor {
  id        Int      @id @default(autoincrement())
  thesisId  Int
  personId  Int
  roleType  String   @default("Principal") // e.g. Principal, Co-asesor
  joinedAt  DateTime @default(now())

  thesis    Thesis   @relation(fields: [thesisId], references: [id], onDelete: Cascade)
  person    Person   @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@unique([thesisId, personId])
  @@index([personId])
  @@index([thesisId])
}

model ThesisJury {
  id        Int      @id @default(autoincrement())
  thesisId  Int
  personId  Int
  assignedAt DateTime @default(now())

  thesis    Thesis   @relation(fields: [thesisId], references: [id], onDelete: Cascade)
  person    Person   @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@unique([thesisId, personId])
  @@index([personId])
  @@index([thesisId])
}

model Setting {
  id          Int      @id @default(1)
  companyName String   @default("GestSoft")
  smtpHost    String?
  smtpPort    String?
  smtpUser    String?
  smtpPass    String?
  smtpFrom    String?
  logoUrl     String?  @default("/logo.webp")
  primaryColor String?  @default("#465fff")
  secondaryColor String? @default("#475467")
  successColor String? @default("#12b76a")
  confirmColor String? @default("#f79009")
  groqApiKey   String?
  groqModel    String?  @default("llama-3.3-70b-versatile")
  updatedAt   DateTime @updatedAt
}

model Sede {
  id                     Int      @id @default(autoincrement())
  name                   String   @unique
  rectorId               Int?
  address                String?
  email                  String?
  phone                  String?
  contextoInstitucional  String?  @db.Text
  misionInstitucional    String?  @db.Text
  visionInstitucional    String?  @db.Text
  createdAt              DateTime @default(now())
  
  rector     Person?     @relation("SedeRector", fields: [rectorId], references: [id])
  oficinas   Oficina[]
  facultades Faculty[]

  @@index([rectorId])
}

model Oficina {
  id          Int         @id @default(autoincrement())
  name        String      @unique
  sedeId      Int
  description String?     @db.Text
  createdAt   DateTime    @default(now())

  sede        Sede        @relation(fields: [sedeId], references: [id], onDelete: Cascade)
  directivos  Directivo[]

  @@index([sedeId])
}

model Directivo {
  id          Int      @id @default(autoincrement())
  oficinaId   Int
  personId    Int
  cargo       String   @default("Integrante") // Director, Integrante, etc.
  joinedAt    DateTime @default(now())

  oficina     Oficina  @relation(fields: [oficinaId], references: [id], onDelete: Cascade)
  person      Person   @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@unique([oficinaId, personId])
  @@index([oficinaId])
  @@index([personId])
}

model Factor {
  id          Int      @id @default(autoincrement())
  number      Int      @unique
  name        String   @unique
  description String?  @db.Text
  createdAt   DateTime @default(now())
}

model Documento {
  id                     Int      @id @default(autoincrement())
  type                   String   // "Registro Calificado" or "Documento de acreditación"
  year                   Int
  programId              Int
  description            String?  @db.Text
  status                 String?
  content                String?  @db.LongText
  coverPage              String?  @db.LongText
  contextoInstitucional  String?  @db.LongText
  misionInstitucional    String?  @db.LongText
  visionInstitucional    String?  @db.LongText
  presentacionFacultad   String?  @db.LongText
  presentacionPrograma   String?  @db.LongText
  createdAt              DateTime @default(now())

  program     Program  @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@index([programId])
}
