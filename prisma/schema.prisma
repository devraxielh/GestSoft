generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Role {
  id          Int          @id @default(autoincrement())
  name        String       @unique
  createdAt   DateTime     @default(now())
  users       User[]
  permissions Permission[] @relation("PermissionToRole")
}

model Permission {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  roles       Role[]   @relation("PermissionToRole")
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String
  active    Boolean  @default(true)
  roleId    Int
  createdAt DateTime @default(now())
  image     String?
  role      Role     @relation(fields: [roleId], references: [id])

  @@index([roleId], map: "User_roleId_fkey")
}

model Faculty {
  id       Int       @id @default(autoincrement())
  name     String    @unique
  address  String?
  deanName String    @default("Sin asignar")
  email    String?
  phone    String?
  programs Program[]
}

model Program {
  id           Int      @id @default(autoincrement())
  name         String   @unique
  facultyId    Int
  address      String?
  directorName String   @default("Sin asignar")
  email        String?
  phone        String?
  persons      Person[]
  theses       Thesis[]
  faculty      Faculty  @relation(fields: [facultyId], references: [id])

  @@index([facultyId], map: "Program_facultyId_fkey")
}

model Person {
  id             Int                     @id @default(autoincrement())
  idType         String
  identification String                  @unique
  phone          String?
  email          String
  createdAt      DateTime                @default(now())
  programId      Int?
  fullName       String
  assignments    CertificateAssignment[]
  program        Program?                @relation(fields: [programId], references: [id])

  studentTheses  ThesisStudent[]
  advisorTheses  ThesisAdvisor[]
  juryTheses     ThesisJury[]

  @@index([programId], map: "Person_programId_fkey")
}

model Event {
  id           Int           @id @default(autoincrement())
  name         String
  startDate    DateTime
  endDate      DateTime
  description  String?       @db.Text
  eventType    String
  createdAt    DateTime      @default(now())
  status       String        @default("Realizado")
  certificates Certificate[]
}

model Certificate {
  id                Int                     @id @default(autoincrement())
  participationType String
  templateHtml      String                  @db.LongText
  eventId           Int
  issueDate         DateTime
  createdAt         DateTime                @default(now())
  event             Event                   @relation(fields: [eventId], references: [id])
  assignments       CertificateAssignment[]

  @@index([eventId], map: "Certificate_eventId_fkey")
}

model CertificateAssignment {
  id                   Int         @id @default(autoincrement())
  certificateId        Int
  personId             Int
  createdAt            DateTime    @default(now())
  participationDetails String?     @db.Text
  certificate          Certificate @relation(fields: [certificateId], references: [id])
  person               Person      @relation(fields: [personId], references: [id])

  @@index([personId], map: "CertificateAssignment_personId_fkey")
  @@index([certificateId], map: "CertificateAssignment_certificateId_fkey")
}

model Thesis {
  id           Int       @id @default(autoincrement())
  title        String    @db.Text
  level        String    // pregrado, especializacion, maestria, doctorado
  defenseDate  DateTime?
  grade        Float?
  status       String    @default("En desarrollo") // en desarrollo, terminada
  programId    Int
  createdAt    DateTime  @default(now())
  
  program      Program   @relation(fields: [programId], references: [id])
  students     ThesisStudent[]
  advisors     ThesisAdvisor[]
  juries       ThesisJury[]

  @@index([programId])
}

model ThesisStudent {
  id        Int      @id @default(autoincrement())
  thesisId  Int
  personId  Int
  joinedAt  DateTime @default(now())

  thesis    Thesis   @relation(fields: [thesisId], references: [id], onDelete: Cascade)
  person    Person   @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@unique([thesisId, personId])
  @@index([personId])
  @@index([thesisId])
}

model ThesisAdvisor {
  id        Int      @id @default(autoincrement())
  thesisId  Int
  personId  Int
  roleType  String   @default("Principal") // e.g. Principal, Co-asesor
  joinedAt  DateTime @default(now())

  thesis    Thesis   @relation(fields: [thesisId], references: [id], onDelete: Cascade)
  person    Person   @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@unique([thesisId, personId])
  @@index([personId])
  @@index([thesisId])
}

model ThesisJury {
  id        Int      @id @default(autoincrement())
  thesisId  Int
  personId  Int
  assignedAt DateTime @default(now())

  thesis    Thesis   @relation(fields: [thesisId], references: [id], onDelete: Cascade)
  person    Person   @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@unique([thesisId, personId])
  @@index([personId])
  @@index([thesisId])
}

model Setting {
  id          Int      @id @default(1)
  companyName String   @default("GestSoft")
  smtpHost    String?
  smtpPort    String?
  smtpUser    String?
  smtpPass    String?
  smtpFrom    String?
  logoUrl     String?  @default("/logo.webp")
  updatedAt   DateTime @updatedAt
}
